<?xml version="1.0" encoding="utf-8"?>
<!--
  Themes for Android 8-11 (API 26-30).
  core-splashscreen compat layer reads windowSplashScreenBackground,
  windowSplashScreenAnimatedIcon, and postSplashScreenTheme from here.
  We also add windowBackground so the splash drawable shows instantly
  before Compose inflates, preventing a white flash on older devices.
-->
<resources>
    <!-- Base app theme -->
    <style name="Theme.StudyFlow" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- No white flash: show splash bg until Compose is ready -->
        <item name="android:windowBackground">@drawable/splash_screen</item>
    </style>

    <!-- Splash theme — uses androidx.core:core-splashscreen compat -->
    <style name="Theme.StudyFlow.Splash" parent="Theme.SplashScreen">
        <!-- Purple background (compat attribute) -->
        <item name="windowSplashScreenBackground">#6D28D9</item>
        <!-- Icon centred on splash (compat attribute) -->
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher_foreground</item>
        <!-- Switch to full app theme after splash -->
        <item name="postSplashScreenTheme">@style/Theme.StudyFlow</item>
    </style>
</resources>
