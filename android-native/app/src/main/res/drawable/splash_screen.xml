<?xml version="1.0" encoding="utf-8"?>
<!--
  Splash screen background drawable used on Android 8-11 (API 26-30).
  On Android 12+ the OS splash screen handles this natively via themes.xml.
  This drawable centres the app icon on a solid purple background.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Solid purple background -->
    <item>
        <color android:color="#6D28D9" />
    </item>
    <!-- Centred app icon, scaled to ~25% of screen width -->
    <item
        android:gravity="center"
        android:width="96dp"
        android:height="96dp">
        <bitmap
            android:src="@mipmap/ic_launcher_foreground"
            android:gravity="center" />
    </item>
</layer-list>
